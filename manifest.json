{
  "manifest_version": 3,
  "name": "Blackboard Dark Mode",
  "short_name": "BB Dark Mode",
  "version": "1.0.0",
  "description": "Dark Mode for Blackboard Ultra (elearn.ku.ac.ae)",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://elearn.ku.ac.ae/*"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ],
      "css": [
        "dark-mode.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Blackboard Dark Mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://elearn.ku.ac.ae/*"
  ]
}
